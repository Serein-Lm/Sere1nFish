# Optional proxy for image builds and package installation only.
# Runtime containers explicitly clear proxy environment variables.
# HTTP_PROXY=http://127.0.0.1:18818
# HTTPS_PROXY=http://127.0.0.1:18818

# Optional LLM gateway used by the backend runtime.
OPENAI_BASE_URL=
OPENAI_API_KEY=

# EasyTier public server for remote mobile access.
# Set this to the public IPv4/domain that phones can reach.
EASYTIER_PUBLIC_HOST=
EASYTIER_NETWORK_NAME=sere1nfish-mobile
# Required in production: replace with a high-entropy secret before exposing ports.
EASYTIER_NETWORK_SECRET=change-me-before-production
EASYTIER_HOSTNAME=sere1nfish-public-server
EASYTIER_VIRTUAL_CIDR=10.144.144.0/24
EASYTIER_BACKEND_HOSTNAME=sere1nfish-backend-peer
EASYTIER_BACKEND_IPV4=10.144.144.1
EASYTIER_BACKEND_DEV=et0
EASYTIER_AUTO_SCAN_ENABLED=true
EASYTIER_ADB_SCAN_TIMEOUT=0.25
EASYTIER_ADB_SCAN_WORKERS=128
EASYTIER_ADB_SCAN_MAX_HOSTS=512
EASYTIER_PORT=11010
EASYTIER_WS_PORT=11011
EASYTIER_WSS_PORT=11012
EASYTIER_WG_PORT=11013
EASYTIER_ANDROID_DOWNLOAD_URL=/api/v1/downloads/mobile/easytier/f4d0f795c2dc283fff573e29690cec54/easytier-v2.6.4-arm64.apk

# Project mobile Agent APK URL shown in the frontend QR onboarding dialog.
MOBILE_AGENT_ANDROID_URL=
MOBILE_AGENT_ADB_PORT=5555

# Runtime artifact downloads. In the deployment repo this can be an absolute
# path outside deploy/; it is mounted read-only to /srv/downloads.
DOWNLOADS_DIR=./downloads
