FROM node:22-bookworm-slim AS node-runtime

FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/ \
    PIP_TRUSTED_HOST=mirrors.aliyun.com \
    ANDROID_HOME=/opt/android-sdk \
    ANDROID_SDK_ROOT=/opt/android-sdk \
    PATH=/opt/android-sdk/platform-tools:$PATH

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG ANDROID_PLATFORM_TOOLS_URL=https://dl.google.com/android/repository/platform-tools-latest-linux.zip

RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || true

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    ffmpeg \
    libgl1 \
    libglib2.0-0 \
    libgomp1 \
    libsm6 \
    libxext6 \
    libxrender1 \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# chrome-devtools-mcp follows the active Node.js LTS engine range. Keep the
# runtime on the official Node image instead of Debian's older nodejs package.
COPY --from=node-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=node-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && node --version \
    && npx --version

RUN mkdir -p /opt/android-sdk \
    && curl -fsSL "${ANDROID_PLATFORM_TOOLS_URL}" -o /tmp/platform-tools.zip \
    && unzip -q /tmp/platform-tools.zip -d /opt/android-sdk \
    && rm /tmp/platform-tools.zip \
    && ln -sf /opt/android-sdk/platform-tools/adb /usr/local/bin/adb \
    && adb version

WORKDIR /app

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Pin the MCP executable in the image. Runtime workers must never race through
# a shared npx installation cache when a large Chrome pool starts concurrently.
ARG CHROME_DEVTOOLS_MCP_VERSION=1.6.0
RUN npm install --global "chrome-devtools-mcp@${CHROME_DEVTOOLS_MCP_VERSION}" \
    && chrome-devtools-mcp --version \
    && npm cache clean --force

CMD ["python", "run.py"]
